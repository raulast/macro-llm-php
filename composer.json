{
    "name": "macro-llm/macro-llm-php",
    "description": "A Composer package that extends Laravel's HTTP client through PHP macros to provide a unified, provider-agnostic interface for interacting with AI providers.",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.1",
        "guzzlehttp/promises": "^2.0",
        "illuminate/http": "^10.0|^11.0",
        "illuminate/support": "^10.0|^11.0",
        "nyholm/psr7": "^1.0",
        "psr/container": "^2.0",
        "psr/http-message": "^1.0|^2.0",
        "psr/http-server-middleware": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "MacroLLM\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MacroLLM\\Integration\\Laravel\\MacroLLMServiceProvider"
            ],
            "aliases": {
                "MacroLLM": "MacroLLM\\Integration\\Laravel\\MacroLLMFacade"
            }
        }
    },
    "config": {
        "sort-packages": true
    }
}
